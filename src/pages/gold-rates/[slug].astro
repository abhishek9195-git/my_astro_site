---
import BaseLayout from "../../layouts/BaseLayout.astro";
import data from "../../data/data.json";
import type { DataFile, Country, State, City, Price } from "../../types";
import GoldChart from "../../components/GoldChart.astro";
import { getCollection, render } from "astro:content";

const typedData: DataFile = data;
const { slug } = Astro.params;

function findEntity(slug: string, countries: Country[]): Country | State | City | null {
  for (const country of countries) {
    if (country.slug === slug) return country;
    for (const state of country.states) {
      if (state.slug === slug) return state;
      for (const city of state.cities) {
        if (city.slug === slug) return city;
      }
    }
  }
  return null;
}

const entity = findEntity(slug, typedData.countries);
const latestGold: Price | undefined = entity?.gold_prices?.slice(-1)[0];

export async function getStaticPaths() {
  const slugs: string[] = [];
  for (const country of data.countries) {
    slugs.push(country.slug);
    for (const state of country.states) {
      slugs.push(state.slug);
      for (const city of state.cities) {
        slugs.push(city.slug);
      }
    }
  }
  return slugs.map((slug) => ({ params: { slug } }));
}

// Load Markdown content for this slug
const seoContent = (await getCollection("gold-rates")).find((entry: any) => entry.data.slug === slug);
// const allEntries = await getCollection("gold-rates");
// console.log("==> allEntries", allEntries);

let rendered;
if (seoContent) {
  rendered = await render(seoContent);
  console.log('==> rendered', rendered)

}
---

<BaseLayout 
  title={`Today’s Gold Rate in ${entity?.name} – 18k, 22k, 24k Prices`} 
  description={`Check today’s gold price in ${entity?.name} for 18k, 22k, and 24k. Updated daily with live rates, charts, and FAQs.`}
>
  <!-- Page Content -->
  <h1 class="text-3xl font-bold mb-2">Gold Price in {entity?.name} Today</h1>
  <p class="text-sm text-gray-600 mb-6">Updated on {latestGold?.date}</p>

  <!-- Latest Prices -->
  <section class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-xl font-semibold mb-4">Latest Gold Rates</h2>
    <ul class="space-y-2">
      {entity?.gold_prices.map((price: Price) => (
        <li class="flex justify-between border-b pb-2">
          <span>{price.carat}</span>
          <span class="font-medium">₹{price.price} <span class="text-sm text-gray-500">({price.unit})</span></span>
        </li>
      ))}
    </ul>
  </section>

  <!-- Chart -->
  <section class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-xl font-semibold mb-4">Gold Price Trend</h2>
    {entity?.gold_prices && <GoldChart prices={entity.gold_prices} />}
  </section>

  <!-- Historical Table -->
  <section class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-xl font-semibold mb-4">Price History</h2>
    <table class="w-full border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-100">
        <tr>
          <th class="border px-3 py-2 text-left">Carat</th>
          <th class="border px-3 py-2 text-left">Price</th>
          <th class="border px-3 py-2 text-left">Unit</th>
          <th class="border px-3 py-2 text-left">Date</th>
        </tr>
      </thead>
      <tbody>
        {entity?.gold_prices.map((price: Price) => (
          <tr>
            <td class="border px-3 py-2">{price.carat}</td>
            <td class="border px-3 py-2">₹{price.price}</td>
            <td class="border px-3 py-2">{price.unit}</td>
            <td class="border px-3 py-2">{price.date}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <!-- Dynamic SEO Content from Markdown -->
  {seoContent && rendered && (
    <section class="bg-white shadow rounded-lg p-6 mb-8">
      <h2 class="text-xl font-semibold mb-4">{seoContent.data.title}</h2>
      <rendered.Content /> <!-- ✅ renders Markdown body -->
    </section>
  )}

  <!-- FAQs from Markdown frontmatter -->
  {seoContent?.data.faqs && seoContent.data.faqs.length > 0 && (
    <section class="bg-white shadow rounded-lg p-6 mb-8">
      <h2 class="text-xl font-semibold mb-4">FAQs</h2>
      {seoContent.data.faqs.map((faq) => (
        <details class="mb-3">
          <summary class="cursor-pointer font-medium">{faq.question}</summary>
          <p class="mt-2 text-gray-700">{faq.answer}</p>
        </details>
      ))}
    </section>
  )}
</BaseLayout>
