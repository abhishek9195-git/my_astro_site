---
import BaseLayout from "../../layouts/BaseLayout.astro";
import data from "../../data/data.json";
import type { DataFile, Country, State, City, Price } from "../../types";
import GoldChart from "../../components/GoldChart.astro";

const typedData: DataFile = data;
const { slug } = Astro.params;

function findEntity(slug: string, countries: Country[]): Country | State | City | null {
  for (const country of countries) {
    if (country.slug === slug) return country;
    for (const state of country.states) {
      if (state.slug === slug) return state;
      for (const city of state.cities) {
        if (city.slug === slug) return city;
      }
    }
  }
  return null;
}

const entity = findEntity(slug, typedData.countries);
const latestGold: Price | undefined = entity?.gold_prices?.slice(-1)[0];

export async function getStaticPaths() {
  const slugs: string[] = [];
  for (const country of data.countries) {
    slugs.push(country.slug);
    for (const state of country.states) {
      slugs.push(state.slug);
      for (const city of state.cities) {
        slugs.push(city.slug);
      }
    }
  }
  return slugs.map((slug) => ({ params: { slug } }));
}
---

<BaseLayout title={`Today’s Gold Rate in ${entity?.name} – 18k, 22k, 24k Prices`} description={`Check today’s gold price in ${entity?.name} for 18k, 22k, and 24k. Updated daily with live rates, charts, and FAQs.`}>
  <!-- Breadcrumb Schema -->
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://yoursite.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Gold Rates",
          "item": "https://yoursite.com/gold-rates"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Gold Rate in ${entity?.name}",
          "item": "https://yoursite.com/gold-rates/${entity?.slug}"
        }
      ]
    }
    </script>
  </Fragment>

  <Fragment slot="head">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is today’s gold rate in {entity?.name}?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Today’s gold rate in {entity?.name} is ₹{latestGold?.price} for {latestGold?.carat} per {latestGold?.unit}."
        }
      },
      {
        "@type": "Question",
        "name": "How often are gold prices updated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Prices are updated daily based on market fluctuations."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between 22k and 24k gold?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "22k gold contains 91.6% pure gold mixed with alloys for durability, while 24k is 99.9% pure and softer."
        }
      }
    ]
  }
  </script>
</Fragment>


  <!-- Page Content -->
  <h1 class="text-3xl font-bold mb-2">Gold Price in {entity?.name} Today</h1>
  <p class="text-sm text-gray-600 mb-6">Updated on {latestGold?.date}</p>

  <!-- Breadcrumb -->
  <nav class="text-sm mb-4" aria-label="Breadcrumb">
    <ol class="list-reset flex text-gray-600">
      <li><a href="/" class="hover:text-blue-600">Home</a></li>
      <li><span class="mx-2">›</span></li>
      <li><a href="/gold-rates" class="hover:text-blue-600">Gold Rates</a></li>
      <li><span class="mx-2">›</span></li>
      <li class="text-gray-900 font-medium">{entity?.name}</li>
    </ol>
  </nav>

  <!-- Latest Prices -->
  <section class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-xl font-semibold mb-4">Latest Gold Rates</h2>
    <ul class="space-y-2">
      {entity?.gold_prices.map((price: Price) => (
        <li class="flex justify-between border-b pb-2">
          <span>{price.carat}</span>
          <span class="font-medium">₹{price.price} <span class="text-sm text-gray-500">({price.unit})</span></span>
        </li>
      ))}
    </ul>
  </section>

  <!-- Chart -->
  <section class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-xl font-semibold mb-4">Gold Price Trend</h2>
    {entity?.gold_prices && <GoldChart prices={entity.gold_prices} />}
  </section>

  <!-- Historical Table -->
  <section class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-xl font-semibold mb-4">Price History</h2>
    <table class="w-full border-collapse border border-gray-200 text-sm">
      <thead class="bg-gray-100">
        <tr>
          <th class="border px-3 py-2 text-left">Carat</th>
          <th class="border px-3 py-2 text-left">Price</th>
          <th class="border px-3 py-2 text-left">Unit</th>
          <th class="border px-3 py-2 text-left">Date</th>
        </tr>
      </thead>
      <tbody>
        {entity?.gold_prices.map((price: Price) => (
          <tr>
            <td class="border px-3 py-2">{price.carat}</td>
            <td class="border px-3 py-2">₹{price.price}</td>
            <td class="border px-3 py-2">{price.unit}</td>
            <td class="border px-3 py-2">{price.date}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <!-- SEO Content Block -->
  <section class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-xl font-semibold mb-4">Factors Affecting Gold Price in {entity?.name}</h2>
    <p class="leading-relaxed text-gray-700">
      Gold prices in {entity?.name} are influenced by international bullion markets,
      currency exchange rates, local demand during festivals, and government import duties.
      22k gold remains the most popular choice for jewelry, while 24k is preferred for investment.
    </p>
  </section>

  <!-- FAQs -->
  <section class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-xl font-semibold mb-4">FAQs</h2>
    <details class="mb-3">
      <summary class="cursor-pointer font-medium">What is today’s gold rate in {entity?.name}?</summary>
      <p class="mt-2 text-gray-700">Today’s gold rate in {entity?.name} is ₹{latestGold?.price} for {latestGold?.carat} per {latestGold?.unit}.</p>
    </details>
    <details class="mb-3">
      <summary class="cursor-pointer font-medium">How often are gold prices updated?</summary>
      <p class="mt-2 text-gray-700">Prices are updated daily based on market fluctuations.</p>
    </details>
    <details>
      <summary class="cursor-pointer font-medium">What is the difference between 22k and 24k gold?</summary>
      <p class="mt-2 text-gray-700">22k gold contains 91.6% pure gold mixed with alloys for durability, while 24k is 99.9% pure and softer.</p>
    </details>
  </section>
</BaseLayout>
