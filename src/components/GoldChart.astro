---
import type { Price } from "../types";

interface Props {
  prices: Price[];
}

const { prices }: Props = Astro.props;

const labels: string[] = prices.map((p) => p.date);
const dataPoints: number[] = prices.map((p) => p.price);
---

<!-- Chart Wrapper with fixed height -->
<div class="w-full">
  <!-- Toggle Buttons -->
  <div class="flex justify-end mb-2 space-x-2">
    <button id="btn7" class="px-3 py-1 bg-gray-200 rounded hover:bg-gray-300">7 Days</button>
    <button id="btn30" class="px-3 py-1 bg-gray-200 rounded hover:bg-gray-300">30 Days</button>
  </div>

  <!-- Chart container with fixed height -->
  <div class="relative w-full h-72">
    <canvas 
      id="goldChart" 
      class="w-full h-full"
      data-labels={JSON.stringify(labels)} 
      data-prices={JSON.stringify(dataPoints)}>
    </canvas>
  </div>
</div>

<script type="module">
  import { Chart, registerables } from "chart.js";
  Chart.register(...registerables);

  const canvas = document.getElementById("goldChart");
  if (!(canvas instanceof HTMLCanvasElement)) throw new Error("Gold chart canvas not found");

  const labels = JSON.parse(canvas.getAttribute("data-labels") || "[]");
  const dataPoints = JSON.parse(canvas.getAttribute("data-prices") || "[]");

  const ctx = canvas.getContext("2d");
  if (!ctx) throw new Error("Unable to get 2D context for gold chart");

  function getSlice(days) {
    return {
      labels: labels.slice(-days),
      data: dataPoints.slice(-days)
    };
  }

  // Initial chart (7 days)
  let { labels: initLabels, data: initData } = getSlice(7);

  const chart = new Chart(ctx, {
    type: "line",
    data: {
      labels: initLabels,
      datasets: [{
        label: "Gold Price (₹/10g)",
        data: initData,
        borderColor: initData[initData.length - 1] >= initData[0]
          ? "rgba(34,197,94,1)"   // green if price rose
          : "rgba(239,68,68,1)", // red if price fell
        backgroundColor: "rgba(255, 215, 0, 0.2)",
        fill: true,
        tension: 0.3
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false, // fill parent container
      plugins: {
        legend: { display: true },
        tooltip: {
          callbacks: {
            label: (ctx) => `₹${ctx.raw} per 10g`
          }
        }
      },
      scales: {
        y: {
          ticks: {
            callback: (value) => `₹${value}`
          }
        }
      }
    }
  });

  // Toggle handlers
  document.getElementById("btn7").addEventListener("click", () => {
    const { labels: newLabels, data: newData } = getSlice(7);
    chart.data.labels = newLabels;
    chart.data.datasets[0].data = newData;
    chart.update();
  });

  document.getElementById("btn30").addEventListener("click", () => {
    const { labels: newLabels, data: newData } = getSlice(30);
    chart.data.labels = newLabels;
    chart.data.datasets[0].data = newData;
    chart.update();
  });
</script>
