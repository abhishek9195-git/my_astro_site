---
import "../styles/global.css";
---

<header class="bg-white shadow sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-4">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="text-2xl font-bold text-blue-700">MySite</a>
      </div>

      <!-- Centered Nav -->
      <nav class="hidden md:flex flex-1 justify-center space-x-6">
        <a href="/" class="text-gray-700 hover:text-blue-600 transition-colors">Home</a>

        <!-- Mega Dropdown (Click-to-open) -->
        <div class="relative">
          <!-- Trigger -->
          <button id="markets-btn" class="flex items-center text-gray-700 hover:text-blue-600 transition-colors">
            Markets
            <svg class="ml-1 h-4 w-4 text-gray-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Mega Menu Panel -->
          <div id="markets-menu" class="hidden absolute left-1/2 top-full transform -translate-x-1/2 mt-2 
                      w-[650px] bg-white rounded-xl shadow-2xl z-50 
                      border-t border-gray-200 p-8 grid grid-cols-3 gap-8">
            <!-- Column 1 -->
            <div>
              <h3 class="text-sm font-semibold text-gray-500 uppercase mb-3">Equities</h3>
              <a href="/markets/stocks" class="flex items-center px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition">📈 <span class="ml-2">Stocks</span></a>
              <a href="/markets/ipo" class="flex items-center px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition">🚀 <span class="ml-2">IPOs</span></a>
              <a href="/markets/indices" class="flex items-center px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition">📊 <span class="ml-2">Indices</span></a>
            </div>

            <!-- Column 2 -->
            <div>
              <h3 class="text-sm font-semibold text-gray-500 uppercase mb-3">Investments</h3>
              <a href="/markets/mutual-funds" class="flex items-center px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition">💰 <span class="ml-2">Mutual Funds</span></a>
              <a href="/markets/etfs" class="flex items-center px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition">📦 <span class="ml-2">ETFs</span></a>
              <a href="/markets/bonds" class="flex items-center px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition">🏦 <span class="ml-2">Bonds</span></a>
            </div>

            <!-- Column 3 -->
            <div>
              <h3 class="text-sm font-semibold text-gray-500 uppercase mb-3">Commodities</h3>
              <a href="/markets/gold" class="flex items-center px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition">🥇 <span class="ml-2">Gold</span></a>
              <a href="/markets/silver" class="flex items-center px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition">🥈 <span class="ml-2">Silver</span></a>
              <a href="/markets/oil" class="flex items-center px-3 py-2 text-gray-700 hover:bg-blue-50 hover:text-blue-600 rounded-lg transition">🛢️ <span class="ml-2">Oil</span></a>
            </div>
          </div>
        </div>

        <a href="/gold-rates" class="text-gray-700 hover:text-blue-600 transition-colors">Gold Rates</a>
        <a href="/news" class="text-gray-700 hover:text-blue-600 transition-colors">News</a>
        <a href="/contact" class="text-gray-700 hover:text-blue-600 transition-colors">Contact</a>
      </nav>

      <!-- Right Side (Search) -->
      <div class="hidden md:flex items-center">
        <form action="/search" method="GET" class="relative">
          <input 
            type="text" 
            name="q" 
            placeholder="Search..." 
            class="w-40 lg:w-56 px-3 py-2 border rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
          />
          <button type="submit" class="absolute right-2 top-1.5 text-gray-500 hover:text-blue-600">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 1110.5 3a7.5 7.5 0 016.15 13.65z" />
            </svg>
          </button>
        </form>
      </div>

      <!-- Mobile Hamburger -->
      <div class="md:hidden">
        <button id="menu-btn" class="text-gray-700 focus:outline-none">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-gray-50 border-t">
    <nav class="flex flex-col p-4 space-y-2">
      <a href="/" class="text-gray-700 hover:text-blue-600">Home</a>
      <details>
        <summary class="cursor-pointer text-gray-700 hover:text-blue-600 flex items-center">
          Markets
          <svg class="ml-1 h-4 w-4 text-gray-500 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="pl-4 flex flex-col space-y-1">
          <a href="/markets/stocks" class="text-gray-600 hover:text-blue-500">📈 Stocks</a>
          <a href="/markets/mutual-funds" class="text-gray-600 hover:text-blue-500">💰 Mutual Funds</a>
          <a href="/markets/commodities" class="text-gray-600 hover:text-blue-500">⚖️ Commodities</a>
        </div>
      </details>
      <a href="/gold-rates" class="text-gray-700 hover:text-blue-600">Gold Rates</a>
      <a href="/news" class="text-gray-700 hover:text-blue-600">News</a>
      <a href="/contact" class="text-gray-700 hover:text-blue-600">Contact</a>

      <!-- Mobile Search -->
      <form action="/search" method="GET" class="mt-4">
        <input 
          type="text" 
          name="q" 
          placeholder="Search..." 
          class="w-full px-3 py-2 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
        />
      </form>
    </nav>
  </div>
</header>


<script>
  // Mobile menu toggle
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");
  if (btn && menu) {
    btn.addEventListener("click", () => {
      menu.classList.toggle("hidden");
    });
  }

  // Mega menu toggle (click-to-open)
  const marketsBtn = document.getElementById("markets-btn");
  const marketsMenu = document.getElementById("markets-menu");
  const marketsIcon = marketsBtn ? marketsBtn.querySelector("svg") : null;

  if (marketsBtn && marketsMenu) {
    marketsBtn.addEventListener("click", (e) => {
      e.stopPropagation(); // prevent bubbling
      const isHidden = marketsMenu.classList.contains("hidden");
      marketsMenu.classList.toggle("hidden");

      // Rotate icon when menu is open
      if (marketsIcon) {
        if (isHidden) {
          marketsIcon.classList.add("rotate-180");
        } else {
          marketsIcon.classList.remove("rotate-180");
        }
      }
    });

    // Close mega menu when clicking outside
    document.addEventListener("click", (e: any) => {
      if (!marketsBtn.contains(e.target) && !marketsMenu.contains(e.target)) {
        marketsMenu.classList.add("hidden");
        if (marketsIcon) {
          marketsIcon.classList.remove("rotate-180");
        }
      }
    });

    // Close mega menu on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        marketsMenu.classList.add("hidden");
        if (marketsIcon) {
          marketsIcon.classList.remove("rotate-180");
        }
      }
    });
  }
</script>

<style>
  /* Rotate caret icon for mobile details when open */
  #mobile-menu details[open] summary svg {
    transform: rotate(180deg);
    transition: transform 0.2s ease-in-out;
  }

  /* Ensure summary svg has smooth transition even when closed */
  #mobile-menu summary svg {
    transition: transform 0.2s ease-in-out;
  }
</style>
