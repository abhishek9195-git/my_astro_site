---
import { getCollection } from "astro:content";

const content = (await getCollection("gold-pros-cons")).find(
  (entry) => entry.data.slug === "gold"
);
---

<section class="rounded-2xl bg-white border border-gray-200 p-6 sm:p-8 shadow-sm shadow-gray-200/60 space-y-8">
  <div class="border-b border-gray-200/80 pb-4">
    <h2 class="text-2xl font-bold text-slate-900">{content?.data.title || "Pros & Cons of Gold Purity"}</h2>
    <p class="text-xs text-slate-500 mt-1">Comparing characteristics across different carats to help guide your choice.</p>
  </div>

  <div class="space-y-8">
    {content?.data.items.map((item) => (
      <article class="p-6 rounded-2xl bg-gray-50/50 border border-gray-200/80 space-y-5 transition-all duration-300 hover:border-gray-300 hover:shadow-sm">
        
        <!-- Carat Header Badge -->
        <div class="flex items-center gap-3">
          <span class="px-3.5 py-1 text-xs font-bold uppercase tracking-wider bg-slate-900 text-white rounded-full">
            {item.carat}
          </span>
          <div class="h-px bg-gray-200 flex-1"></div>
        </div>

        <!-- Pros & Cons Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          
          <!-- Pros Box -->
          <div class="rounded-xl bg-white border border-emerald-100 p-4 shadow-sm shadow-emerald-500/5">
            <div class="flex items-center gap-2 mb-3 text-emerald-700 font-semibold text-sm">
              <span class="w-5 h-5 rounded-full bg-emerald-100 text-emerald-700 flex items-center justify-center text-xs font-bold">+</span>
              Pros
            </div>
            <ul class="space-y-2">
              {item.pros.map((p) => (
                <li class="flex items-start gap-2 text-xs text-slate-600 leading-relaxed">
                  <span class="text-emerald-500 mt-0.5">•</span>
                  <span>{p}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Cons Box -->
          <div class="rounded-xl bg-white border border-rose-100 p-4 shadow-sm shadow-rose-500/5">
            <div class="flex items-center gap-2 mb-3 text-rose-700 font-semibold text-sm">
              <span class="w-5 h-5 rounded-full bg-rose-100 text-rose-700 flex items-center justify-center text-xs font-bold">-</span>
              Cons
            </div>
            <ul class="space-y-2">
              {item.cons.map((c) => (
                <li class="flex items-start gap-2 text-xs text-slate-600 leading-relaxed">
                  <span class="text-rose-400 mt-0.5">•</span>
                  <span>{c}</span>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </article>
    ))}
  </div>
</section>