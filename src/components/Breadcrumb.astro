---
interface Props {
  breadcrumbs: string[];
}

const { breadcrumbs = [] } = Astro.props;

// Prettify function: replaces hyphens and capitalizes each word
const formatLabel = (str: string) => {
  if (!str) return "";
  return str
    .replace(/-/g, " ")
    .replace(/\b\w/g, (char) => char.toUpperCase());
};

// Generate breadcrumb items with accumulated URLs
const items = breadcrumbs.map((seg, idx) => {
  const href = "/" + breadcrumbs.slice(0, idx + 1).join("/");
  const label = formatLabel(seg);
  const isLast = idx === breadcrumbs.length - 1;
  return { label, href, isLast };
});

// JSON-LD Schema for SEO
const schemaData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://" // Astro base URL or site domain
    },
    ...items.map((item, index) => ({
      "@type": "ListItem",
      "position": index + 2,
      "name": item.label,
      "item": item.href
    }))
  ]
};
---

<!-- Structured Data for Search Engines -->
<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

<nav aria-label="Breadcrumb" class="py-2">
  <ol class="inline-flex items-center space-x-1 sm:space-x-2 text-xs sm:text-sm font-medium text-[#0A1931]/70 flex-wrap gap-y-1">
    
    <!-- Home Item -->
    <li class="inline-flex items-center">
      <a
        href="/"
        class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg hover:bg-[#0A1931]/10 hover:text-[#0A1931] transition-colors"
      >
        <svg class="w-3.5 h-3.5 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 00-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 00-1 1m-6 0h6"></path>
        </svg>
        <span>Home</span>
      </a>
    </li>

    <!-- Breadcrumb Segments -->
    {items.map((item) => (
      <li class="inline-flex items-center">
        <!-- Chevron Separator -->
        <svg class="w-4 h-4 text-[#0A1931]/40 mx-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>

        {item.isLast ? (
          <span 
            class="px-2.5 py-1 rounded-lg bg-[#0A1931]/10 text-[#0A1931] font-bold truncate max-w-[200px] sm:max-w-none" 
            aria-current="page"
          >
            {item.label}
          </span>
        ) : (
          <a
            href={item.href}
            class="px-2.5 py-1 rounded-lg hover:bg-[#0A1931]/10 hover:text-[#0A1931] transition-colors truncate max-w-[150px] sm:max-w-none"
          >
            {item.label}
          </a>
        )}
      </li>
    ))}
  </ol>
</nav>