---
interface Props {
  cityName: string;
  carat24k?: number;
  carat22k?: number;
  carat18k?: number;
  carat14k?: number;
}

const {
  cityName,
  carat24k = 0,
  carat22k = 0,
  carat18k = 0,
  carat14k = 0,
} = Astro.props;
---

<section class="rounded-2xl bg-white border border-[#0A1931]/10 p-6 sm:p-8 shadow-sm shadow-[#0A1931]/5 space-y-6">
  <div class="border-b border-[#0A1931]/10 pb-4">
    <h2 class="text-2xl font-bold text-[#0A1931]">Gold Price Calculator ({cityName})</h2>
    <p class="text-xs opacity-70 mt-1">Estimate total purchase cost including Making Charges & 3% GST</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Carat / Purity Sel,ector -->
    <div>
      <label class="block text-xs font-bold uppercase tracking-wider mb-2 opacity-80" for="calc-carat">
        Select Purity
      </label>
      <select 
        id="calc-carat" 
        class="w-full bg-[#F6FAFD] border border-[#0A1931]/20 rounded-xl px-4 py-2.5 font-semibold text-[#0A1931] focus:outline-none focus:ring-2 focus:ring-[#0A1931]/20"
      >
        <option value={carat24k}>24K (Pure Gold - ₹{carat24k}/g)</option>
        <option value={carat22k} selected>22K (Jewelry Standard - ₹{carat22k}/g)</option>
        <option value={carat18k}>18K (Lifestyle Gold - ₹{carat18k}/g)</option>
        <option value={carat14k}>14K (Durable Gold - ₹{carat14k}/g)</option>
      </select>
    </div>

    <!-- Weight Input -->
    <div>
      <label class="block text-xs font-bold uppercase tracking-wider mb-2 opacity-80" for="calc-weight">
        Weight (Grams)
      </label>
      <input 
        id="calc-weight" 
        type="number" 
        value="10" 
        min="0.1" 
        step="0.1" 
        class="w-full bg-[#F6FAFD] border border-[#0A1931]/20 rounded-xl px-4 py-2.5 font-semibold text-[#0A1931] focus:outline-none focus:ring-2 focus:ring-[#0A1931]/20" 
      />
    </div>

    <!-- Making Charges Input -->
    <div>
      <label class="block text-xs font-bold uppercase tracking-wider mb-2 opacity-80" for="calc-making">
        Making Charges (%)
      </label>
      <input 
        id="calc-making" 
        type="number" 
        value="10" 
        min="0" 
        max="50" 
        step="0.5" 
        class="w-full bg-[#F6FAFD] border border-[#0A1931]/20 rounded-xl px-4 py-2.5 font-semibold text-[#0A1931] focus:outline-none focus:ring-2 focus:ring-[#0A1931]/20" 
      />
    </div>
  </div>

  <!-- Price Breakdown Display -->
  <div class="p-5 rounded-xl bg-[#F6FAFD] border border-[#0A1931]/10 flex flex-wrap justify-between items-center gap-4">
    <div>
      <span class="text-xs opacity-70 uppercase tracking-wider block font-semibold">Estimated Final Price (Incl. 3% GST)</span>
      <span id="calc-result" class="text-3xl font-black text-[#0A1931]">₹0</span>
    </div>
    <div class="text-xs opacity-70 text-right space-y-1">
      <p id="calc-breakdown-base">Base + Making: ₹0</p>
      <p id="calc-breakdown-gst">GST (3%): ₹0</p>
    </div>
  </div>
</section>

<script>
  function updateCalculator() {
    const rateSelect = document.getElementById("calc-carat") as HTMLSelectElement;
    const weightInput = document.getElementById("calc-weight") as HTMLInputElement;
    const makingInput = document.getElementById("calc-making") as HTMLInputElement;

    const rate = parseFloat(rateSelect?.value || "0");
    const weight = parseFloat(weightInput?.value || "0");
    const makingPct = parseFloat(makingInput?.value || "0");

    const rawGoldPrice = rate * weight;
    const makingCharge = rawGoldPrice * (makingPct / 100);
    const subtotal = rawGoldPrice + makingCharge;
    const gst = subtotal * 0.03; // Standard 3% GST on Gold in India
    const grandTotal = subtotal + gst;

    const resultEl = document.getElementById("calc-result");
    const baseEl = document.getElementById("calc-breakdown-base");
    const gstEl = document.getElementById("calc-breakdown-gst");

    if (resultEl) resultEl.textContent = `₹${Math.round(grandTotal).toLocaleString("en-IN")}`;
    if (baseEl) baseEl.textContent = `Base + Making: ₹${Math.round(subtotal).toLocaleString("en-IN")}`;
    if (gstEl) gstEl.textContent = `GST (3%): ₹${Math.round(gst).toLocaleString("en-IN")}`;
  }

  // Attach event listeners safely
  const initCalculator = () => {
    ["calc-carat", "calc-weight", "calc-making"].forEach((id) => {
      document.getElementById(id)?.addEventListener("input", updateCalculator);
      document.getElementById(id)?.addEventListener("change", updateCalculator);
    });
    updateCalculator();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCalculator);
  } else {
    initCalculator();
  }
</script>